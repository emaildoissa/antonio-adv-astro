---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';

// Dados centralizados.
const SITE_DATA = {
  contact: {
    whatsapp: "(51) 98431-4898",
    whatsappLink: "https://wa.me/5551984314898",
    email: "antoniocarlosrosa.adv@gmail.com",
    emailLink: "mailto:antoniocarlosrosa.adv@gmail.com",
    instagram: "https://www.instagram.com/antoniocarlosrosa_advocacia/"
  },
  hero: {
    tagline: "Advocacia Trabalhista e Previdenciária",
    titleStart: "O seu trabalho tem valor. ",
    titleHighlight: "O seu futuro tem amparo.",
    description: "Da defesa incansável dos seus direitos no ambiente corporativo ao planeamento cirúrgico da sua aposentadoria. A nossa precisão técnica protege cada etapa da sua vida profissional."
  },
  connection: {
    titleStart: "A omissão que ",
    titleHighlight: "custa caro.",
    previdenciario: {
      title: "No Direito Previdenciário",
      text: "O sistema brasileiro é um labirinto de normas e prazos. Cada mês de indecisão ou erro processual não é apenas uma falha técnica — é uma fração da sua vida, e do seu património, que não retorna."
    },
    trabalhista: {
      title: "No Direito Trabalhista",
      text: "Relações corporativas muitas vezes ocultam violações silenciosas. Cada hora extra não paga, assédio tolerado ou desvio de função não é um mero contratempo — é a desvalorização direta da sua força e saúde."
    },
    conclusion: "Não tratamos processos como números, mas como o resgate da dignidade conquistada em anos de dedicação. A nossa abordagem une o rigor jurídico à sensibilidade de quem sabe exatamente o que está em jogo."
  },
  authority: [
    { value: "15", label: "Anos de dedicação exclusiva ao direito previdenciário" },
    { value: "1.500+", label: "Futuros protegidos e benefícios conquistados com excelência" }
  ],
  testimonials: [
    {
      text: '"A precisão técnica e o atendimento humanizado fizeram toda a diferença no meu planeamento. Sinto que o meu futuro está finalmente em boas mãos."',
      author: "Dr. Ricardo Menezes",
      role: "Médico Cirurgião"
    },
    {
      text: '"Depois de anos a tentar sozinho, a equipa resolveu a minha aposentadoria especial em meses. Profissionalismo impecável."',
      author: "Beatriz Albuquerque",
      role: "Engenheira Química"
    }
  ],
  cta: {
    titleStart: "Proteja o seu trabalho, ",
    titleHighlight: "garanta o seu futuro.",
    description: "Agende uma análise criteriosa da sua situação trabalhista e previdenciária. A nossa equipa está pronta para defender os seus direitos hoje e blindar a sua aposentadoria amanhã."
  }
};
---

<Layout 
  title="Antonio Carlos Rosa | Advocacia Previdenciária" 
  description="Proteja o seu futuro com a precisão técnica de quem entende que cada segundo de trabalho merece o amparo da lei."
>
  <main class="min-h-screen">
    
    {/* MOBILE NAV MENU */}
    <div id="mobile-menu" class="fixed inset-0 bg-[#0B0B0B]/98 backdrop-blur-lg z-[100] flex-col items-center justify-center p-8 space-y-12 transition-all duration-500 ease-in-out transform translate-x-full hidden md:!hidden">
      <button id="mobile-menu-close" class="absolute top-6 right-6 text-white material-symbols-outlined text-4xl hover:text-[#c9a96e] transition-colors p-2" aria-label="Fechar Menu">
        close
      </button>

      <div class="flex flex-col items-center gap-12">
        <a class="text-[#c9a96e] font-headline text-3xl tracking-tight hover:text-white transition-colors" href="#home">Home</a>
        <a class="text-[#c9a96e] font-headline text-3xl tracking-tight hover:text-white transition-colors" href="#areas">Áreas de Atuação</a>
        <a class="text-[#c9a96e] font-headline text-3xl tracking-tight hover:text-white transition-colors" href="#contact">Falar com Advogado</a>
      </div>
    </div>

    {/* HEADER PREMIUM ESCURO */}
    <header class="bg-[#000000] backdrop-blur-xl border-b border-[#c9a96e]/20 top-0 sticky z-50 w-full transition-all">
      <nav class="flex justify-between items-center w-full px-6 md:px-8 py-4 md:py-5 max-w-screen-2xl mx-auto">
        <div class="flex items-center">
          <img src="/logo.png" alt="Antonio Carlos Rosa Advocacia" class="h-14 md:h-24 w-auto object-contain" />
          <span class="sr-only">Antonio Carlos Rosa Advocacia</span>
        </div>

        <div class="hidden md:flex items-center space-x-12">
          <a class="text-[#F5F5F5]/70 hover:text-primary-container transition-colors font-headline text-lg tracking-tight" href="#home">Home</a>
          <a class="text-[#F5F5F5]/70 hover:text-primary-container transition-colors font-headline text-lg tracking-tight" href="#areas">Áreas</a>
        </div>

        <div class="flex items-center gap-4">
          <a href={SITE_DATA.contact.whatsappLink} target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-4 md:px-7 py-2.5 md:py-3 font-bold rounded-full flex items-center gap-2 hover:bg-[#20ba5a] transition-all duration-300 active:scale-95 text-xs md:text-sm uppercase tracking-wide">
            <span class="material-symbols-outlined text-lg md:text-xl">check_circle</span>
            <span class="hidden sm:inline">WhatsApp</span>
            <span class="sm:hidden">Falar</span>
          </a>

          <button id="mobile-menu-toggle" class="flex md:!hidden items-center justify-center text-white material-symbols-outlined text-3xl hover:text-[#c9a96e] transition-colors p-2 -mr-2" aria-label="Abrir Menu">
            menu
          </button>
        </div>
      </nav>
    </header>

    {/* HERO SECTION */}
    <section id="home" class="relative min-h-[85vh] md:min-h-[921px] flex items-center overflow-hidden pt-16 md:pt-12 pb-16 md:pb-0">
      <div class="max-w-screen-2xl mx-auto px-6 md:px-8 w-full grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12 items-center">
        <div class="md:col-span-7 z-10 text-center md:text-left mt-8 md:mt-0">
          <span class="text-xs md:text-base uppercase tracking-[0.2em] text-primary mb-4 md:mb-6 block font-medium">
            {SITE_DATA.hero.tagline}
          </span>
          <h1 class="font-headline text-4xl sm:text-5xl md:text-7xl lg:text-8xl leading-[1.1] mb-6 md:mb-8 tracking-tight text-[#1a1c1c]">
            {SITE_DATA.hero.titleStart}
            <span class="italic font-normal">{SITE_DATA.hero.titleHighlight}</span>
          </h1>
          <p class="text-lg md:text-2xl text-[#5f5e5e] max-w-xl mb-8 md:mb-12 font-light leading-relaxed mx-auto md:mx-0">
            {SITE_DATA.hero.description}
          </p>
          <div class="flex flex-col sm:flex-row gap-4 md:gap-6 justify-center md:justify-start">
            <a href={SITE_DATA.contact.whatsappLink} target="_blank" rel="noopener noreferrer" class="bg-primary text-white px-8 md:px-10 py-4 md:py-5 text-base md:text-lg font-medium inline-flex items-center justify-center gap-3 hover:bg-primary-container transition-all group rounded-sm w-full sm:w-auto shadow-lg shadow-primary/20">
              <span class="material-symbols-outlined text-2xl text-[#25D366]">check_circle</span>
              Falar com Especialista
              <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform hidden md:inline">arrow_right_alt</span>
            </a>
          </div>
        </div>
        <div class="md:col-span-5 relative mt-8 md:mt-0">
          <div class="aspect-[4/5] bg-surface-container relative overflow-hidden rounded-sm md:rounded-none">
            <img alt="Ambiente Jurídico Premium" class="w-full h-full object-cover grayscale contrast-125 opacity-90" src="/hero.jpeg" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#f9f9f9] md:via-transparent to-transparent"></div>
          </div>
          <div class="hidden md:block absolute -left-6 top-1/4 w-px h-1/2 bg-primary-container"></div>
          <div class="hidden md:block absolute -bottom-6 right-12 h-px w-1/2 bg-primary-container"></div>
        </div>
      </div>
    </section>

    {/* CONNECTION SECTION */}
    <section class="py-20 md:py-40 bg-surface-container-low">
      <div class="max-w-screen-2xl mx-auto px-6 md:px-8">
        <div class="max-w-4xl mb-12 md:mb-24 space-y-6 md:space-y-8 text-center md:text-left">
          <h2 class="font-headline text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-[#1a1c1c] leading-tight">
            {SITE_DATA.connection.titleStart} <span class="text-primary italic font-headline">{SITE_DATA.connection.titleHighlight}</span>
          </h2>
          <div class="w-16 md:w-20 h-1 bg-primary-container mx-auto md:mx-0"></div>
          <p class="text-lg md:text-2xl text-on-surface-variant leading-relaxed font-light text-justify md:text-left">
            {SITE_DATA.connection.conclusion}
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24 pt-12 md:pt-16 border-t border-primary-container/20">
          <div class="space-y-4">
            <div class="flex items-center gap-4 mb-4 md:mb-6">
              <span class="material-symbols-outlined text-primary text-3xl">account_balance</span>
              <h3 class="font-headline text-2xl text-[#1a1c1c]">{SITE_DATA.connection.previdenciario.title}</h3>
            </div>
            <p class="text-on-surface-variant text-base md:text-lg leading-relaxed text-justify">
              {SITE_DATA.connection.previdenciario.text}
            </p>
          </div>

          <div class="space-y-4">
            <div class="flex items-center gap-4 mb-4 md:mb-6">
              <span class="material-symbols-outlined text-primary text-3xl">gavel</span>
              <h3 class="font-headline text-2xl text-[#1a1c1c]">{SITE_DATA.connection.trabalhista.title}</h3>
            </div>
            <p class="text-on-surface-variant text-base md:text-lg leading-relaxed text-justify">
              {SITE_DATA.connection.trabalhista.text}
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* BENTO GRID SECTION (3 FOTOS / 3 CORES SÓLIDAS) */}
    <section class="py-20 md:py-40" id="areas">
      <div class="max-w-screen-2xl mx-auto px-6 md:px-8">
        
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 md:mb-16 gap-6 md:gap-8 text-center md:text-left">
          <div class="max-w-2xl w-full">
            <span class="text-secondary font-body text-xs uppercase tracking-[0.3em] block mb-3 md:mb-4">Especialidades</span>
            <h2 class="font-headline text-4xl sm:text-5xl md:text-6xl text-[#1a1c1c] tracking-tight leading-tight">
              Estratégias para uma vida <span class="italic font-headline">sem renúncias</span>
            </h2>
          </div>
          <div class="md:max-w-xs text-center md:text-right w-full">
            <p class="text-[#5f5e5e] text-sm leading-relaxed mb-6">Navegando pelas complexidades da lei com precisão técnica e autoridade inabalável.</p>
            <div class="h-[1px] bg-outline-variant w-full md:w-auto opacity-50"></div>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 auto-rows-[minmax(180px,auto)] md:grid-flow-dense">
          
          {/* 1. Seguro Desemprego (FOTO) */}
          <div class="md:col-span-8 md:row-span-3 bg-[#0B0B0B] relative overflow-hidden group rounded-sm shadow-sm flex flex-col justify-end cursor-pointer min-h-[350px] md:min-h-0">
            <div class="absolute inset-0 z-0 transition-all duration-700 group-hover:scale-105 group-hover:opacity-20">
              <img alt="Seguro Desemprego" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500" src="https://images.unsplash.com/photo-1507679799987-c73779587ccf?auto=format&fit=crop&q=80"/>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-[#0B0B0B]/90 via-[#0B0B0B]/40 to-transparent z-10 transition-colors duration-500 group-hover:bg-[#0B0B0B]/95"></div>
            
            <div class="relative z-20 p-6 md:p-10 transition-opacity duration-500 group-hover:opacity-0 group-hover:-translate-y-4">
              <span class="text-[0.65rem] md:text-xs uppercase tracking-[0.2em] text-[#c9a96e] mb-2 font-bold block">Direito Trabalhista</span>
              <h3 class="font-headline text-3xl md:text-4xl mb-3 md:mb-4 italic text-white">Seguro Desemprego</h3>
              <p class="max-w-md text-[#e2e2e2] font-light leading-relaxed mb-6 text-sm md:text-base">Orientação profissional para garantir sua transição com dignidade e segurança jurídica.</p>
              
              <div class="flex items-center gap-1.5 text-[0.65rem] md:text-xs uppercase tracking-widest font-bold text-[#c9a96e] group-hover:text-white transition-colors mt-auto w-fit">
                <span class="material-symbols-outlined text-sm md:text-base">touch_app</span> Veja mais
              </div>
            </div>

            <div class="absolute inset-0 text-white p-6 md:p-12 translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] z-30 flex flex-col justify-center">
              <div class="flex items-center gap-3 md:gap-4 mb-4 md:mb-6">
                 <div class="w-8 md:w-16 h-px bg-[#c9a96e]/50"></div>
                 <span class="text-[#c9a96e] font-headline text-xl md:text-2xl italic">O que você precisa saber?</span>
              </div>
              
              <div class="space-y-3 md:space-y-5 font-light text-[0.85rem] md:text-base leading-relaxed text-[#e2e2e2] max-w-3xl">
                <p><strong class="text-white font-medium">Assistência Financeira Temporária.</strong> Um benefício fundamental da seguridade social para garantir a sua subsistência provisória.</p>
                <div class="pl-3 md:pl-4 border-l-2 border-[#c9a96e] text-[#c9a96e] font-medium text-lg md:text-xl font-headline italic py-1">
                  Direito garantido ao trabalhador demitido sem justa causa.
                </div>
                <p class="hidden sm:block">O objetivo é prover manutenção digna enquanto você foca na busca por uma nova recolocação profissional no mercado.</p>
              </div>

              <a href={SITE_DATA.contact.whatsappLink} target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-5 py-2.5 font-bold rounded-sm flex items-center justify-center gap-2 hover:bg-[#20ba5a] transition-all duration-300 active:scale-95 text-[0.65rem] md:text-xs uppercase tracking-wide w-fit mt-6 md:mt-10 shadow-lg shadow-[#25D366]/20">
                <span class="material-symbols-outlined text-base">check_circle</span> Falar com Advogado
              </a>
            </div>
          </div>

          {/* 2. Aposentadoria (SÓLIDO PRETO) */}
          <div class="md:col-span-4 md:row-span-3 bg-[#0B0B0B] relative overflow-hidden group rounded-sm shadow-sm flex flex-col justify-between cursor-pointer min-h-[350px]">
            <div class="relative z-20 p-6 md:p-8 h-full flex flex-col justify-between transition-all duration-500 group-hover:opacity-0 group-hover:-translate-y-4">
              <div>
                <div class="w-10 md:w-12 h-1 bg-[#c9a96e] mb-6"></div>
                <h3 class="font-headline text-2xl md:text-3xl italic text-white mb-3">Aposentadoria por Invalidez</h3>
                <p class="text-[#e2e2e2]/80 leading-relaxed font-light text-sm">Amparo definitivo para segurados com incapacidade total e permanente para o trabalho.</p>
              </div>
              
              <div class="flex items-center gap-1.5 text-[0.65rem] md:text-xs uppercase tracking-widest font-bold text-[#c9a96e] group-hover:text-white transition-colors mt-auto w-fit">
                <span class="material-symbols-outlined text-sm md:text-base">touch_app</span> Veja mais
              </div>
            </div>

            <div class="absolute inset-0 text-white p-6 md:p-8 translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] z-30 flex flex-col justify-center bg-[#1a1c1c]">
              <span class="text-[#c9a96e] font-headline text-xl md:text-2xl mb-3 flex items-center gap-2">
                 <span class="material-symbols-outlined text-lg">health_and_safety</span> Incapacidade Permanente
              </span>
              
              <p class="text-[0.7rem] md:text-[0.75rem] text-[#e2e2e2]/80 mb-5 font-light leading-relaxed">
                Benefício concedido quando não há possibilidade de reabilitação. Principais doenças que dão direito:
              </p>
              
              <ul class="space-y-3 font-light text-[0.7rem] md:text-[0.75rem] leading-relaxed text-[#e2e2e2] border-l-2 border-[#c9a96e] pl-3 mb-6">
                <li><strong class="text-white font-medium block mb-0.5">Mentais e Neurológicas:</strong> Alienação mental, Parkinson e Esclerose.</li>
                <li><strong class="text-white font-medium block mb-0.5">Órgãos Vitais:</strong> Cardiopatia grave e Nefropatias (rins).</li>
                <li><strong class="text-white font-medium block mb-0.5">Físicas/Infecciosas:</strong> Cegueira, Paralisia, Tuberculose e Hanseníase.</li>
              </ul>

              <a href={SITE_DATA.contact.whatsappLink} target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-5 py-2.5 font-bold rounded-sm flex items-center justify-center gap-2 hover:bg-[#20ba5a] transition-all duration-300 active:scale-95 text-[0.65rem] md:text-xs uppercase tracking-wide w-fit mt-auto shadow-lg shadow-[#25D366]/20">
                <span class="material-symbols-outlined text-base">check_circle</span> Falar com Advogado
              </a>
            </div>
          </div>

         {/* 3. Pensão por Morte (FOTO) */}
          <div class="md:col-span-4 md:row-span-3 relative overflow-hidden group rounded-sm shadow-sm flex flex-col justify-between cursor-pointer min-h-[300px]">
            <div class="absolute inset-0 z-0 transition-all duration-700 group-hover:scale-105 group-hover:opacity-20">
              <img alt="Pensão por Morte" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500" src="/pensao.jpeg"/>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-[#0B0B0B]/95 via-[#0B0B0B]/70 to-transparent z-10 transition-colors duration-500 group-hover:bg-[#0B0B0B]/98"></div>

            <div class="relative z-20 p-6 md:p-8 h-full flex flex-col justify-between transition-all duration-500 group-hover:opacity-0 group-hover:-translate-y-4">
              <div>
                <span class="material-symbols-outlined text-[#c9a96e] mb-3 md:mb-4 text-2xl md:text-3xl">family_restroom</span>
                <h3 class="font-headline text-xl md:text-2xl mb-2 text-white">Pensão por Morte</h3>
                <p class="text-[#e2e2e2]/80 text-xs md:text-sm leading-relaxed">Amparo financeiro para os dependentes em momentos de luto.</p>
              </div>
              
              <div class="flex items-center gap-1.5 text-[0.65rem] md:text-xs uppercase tracking-widest font-bold text-[#c9a96e] group-hover:text-white transition-colors mt-auto w-fit">
                <span class="material-symbols-outlined text-sm md:text-base">touch_app</span> Veja mais
              </div>
            </div>

            <div class="absolute inset-0 text-white p-6 md:p-8 translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] z-30 flex flex-col justify-center bg-[#0B0B0B]/90">
              <span class="text-[#c9a96e] font-headline text-base md:text-lg mb-3 flex items-center gap-2">
                 <span class="material-symbols-outlined text-sm">info</span> Regras do Benefício
              </span>
              
              <ul class="space-y-2.5 font-light text-[0.7rem] md:text-[0.75rem] leading-relaxed text-[#e2e2e2] border-l-2 border-[#c9a96e] pl-3 mb-5">
                <li><strong class="text-white font-medium">Cônjuge/Companheiro:</strong> A dependência económica é absoluta.</li>
                <li><strong class="text-white font-medium">Filhos/Enteados:</strong> Menores de 21 anos. Sem limite se houver invalidez grave.</li>
                <li><strong class="text-[#ba1a1a] font-medium">Atenção:</strong> Não se estende até aos 24 anos para universitários.</li>
              </ul>

              <a href={SITE_DATA.contact.whatsappLink} target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-5 py-2.5 font-bold rounded-sm flex items-center justify-center gap-2 hover:bg-[#20ba5a] transition-all duration-300 active:scale-95 text-[0.65rem] md:text-xs uppercase tracking-wide w-fit mt-auto shadow-lg shadow-[#25D366]/20">
                <span class="material-symbols-outlined text-base">check_circle</span> Falar com Advogado
              </a>
            </div>
          </div>

          {/* 4. Assédio no Trabalho (FOTO) */}
          <div class="md:col-span-4 md:row-span-3 relative overflow-hidden group rounded-sm shadow-sm flex flex-col justify-between cursor-pointer min-h-[300px]">
            <div class="absolute inset-0 z-0 transition-all duration-700 group-hover:scale-105 group-hover:opacity-20">
              <img alt="Assédio no Trabalho" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500" src="/assedio.jpg"/>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-[#0B0B0B]/95 via-[#0B0B0B]/70 to-transparent z-10 transition-colors duration-500 group-hover:bg-[#0B0B0B]/98"></div>

            <div class="relative z-20 p-6 md:p-8 h-full flex flex-col justify-between transition-all duration-500 group-hover:opacity-0 group-hover:-translate-y-4">
              <div>
                <div class="inline-block text-[0.6rem] md:text-[0.65rem] uppercase tracking-widest text-[#ba1a1a] font-bold bg-white/10 px-2 py-1 rounded mb-3">
                  <span class="material-symbols-outlined text-[10px] align-middle mr-1">priority_high</span> Urgente
                </div>
                <h3 class="font-headline text-xl md:text-2xl mb-2 md:mb-3 text-white">Assédio no Trabalho</h3>
                <p class="text-[#e2e2e2]/80 text-xs md:text-sm leading-relaxed">Preservando a dignidade e a saúde mental no ambiente profissional.</p>
              </div>
              <div class="flex items-center gap-1.5 text-[0.65rem] md:text-xs uppercase tracking-widest font-bold text-[#c9a96e] group-hover:text-white transition-colors mt-auto w-fit">
                <span class="material-symbols-outlined text-sm md:text-base">touch_app</span> Veja mais
              </div>
            </div>

            <div class="absolute inset-0 text-white p-6 md:p-8 translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] z-30 flex flex-col justify-center bg-[#0B0B0B]/90">
              <span class="text-[#ba1a1a] font-headline text-base md:text-lg mb-2 flex items-center gap-2">
                 <span class="material-symbols-outlined text-sm">gavel</span> O seu direito ao respeito
              </span>
              
              <p class="text-[0.65rem] md:text-[0.75rem] text-[#e2e2e2]/70 mb-3 font-light">
